# ===== MySQL 8 数据库连接 =====
DB_HOST=127.0.0.1
DB_PORT=3306
DB_USER=root
DB_PASSWORD=your_mysql_password
DB_NAME=container_biz
DB_POOL_SIZE=10

# ===== 会话签名密钥（生产环境务必替换为随机长字符串）=====
# 生成方式： openssl rand -base64 32
APP_SECRET=change-me-to-a-long-random-secret-string

# ===== Cookie Secure（可选）=====
# 仅 HTTP 访问（未上 HTTPS）时设为 false，否则登录 Cookie 会被浏览器丢弃
# 上 HTTPS 后改为 true，或不设置（按 X-Forwarded-Proto / APP_BASE_URL 自动判断）
# COOKIE_SECURE=false

# ===== 种子用户默认密码（初始化脚本使用，可选）=====
SEED_PASSWORD=Passw0rd!

# ===== 本应用对外基址（订舱同步默认指向本地 mock feed）=====
APP_BASE_URL=http://127.0.0.1:3000

# ===== 真实 SMTP（预约「发送通知」时发信到堆场 email）=====
# SMTP_HOST=smtp.example.com
# SMTP_PORT=587
# SMTP_SECURE=false
# SMTP_USER=
# SMTP_PASS=
# SMTP_FROM="集装箱业务系统 <noreply@example.com>"

# ===== 外部订舱 API（真实 HTTP GET，返回 { orders: [...] }）=====
# 不填则默认请求 ${APP_BASE_URL}/api/external/booking-feed
# BOOKING_API_URL=http://127.0.0.1:3000/api/external/booking-feed
# BOOKING_API_KEY=

# ===== 订舱出站推送（账单确认后 HTTP POST 投递 outbound_events）=====
# 不填则默认 POST ${APP_BASE_URL}/api/external/booking-outbound（本地 echo）
# BOOKING_OUTBOUND_URL=http://127.0.0.1:3000/api/external/booking-outbound
